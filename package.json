{
  "name": "@carletonuniversity/rds2",
  "version": "0.5.2",
  "description": "React component library and design system for Carleton University",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cuweb/rds2.git"
  },
  "type": "module",
  "private": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "sideEffects": [
    "**/*.css",
    "**/*.scss"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./styles": "./dist/style.css",
    "./styles.css": "./dist/style.css",
    "./vanilla-js/videoCard": {
      "import": "./dist/vanilla-js/videoCard.mjs",
      "default": "./dist/vanilla-js/videoCard.js"
    },
    "./vanilla-js/videoCard.js": "./dist/vanilla-js/videoCard.js",
    "./vanilla-js/cuMotion": {
      "import": "./dist/vanilla-js/cuMotion.mjs",
      "default": "./dist/vanilla-js/cuMotion.js"
    },
    "./vanilla-js/cuMotion.js": "./dist/vanilla-js/cuMotion.js",
    "./*": {
      "types": "./dist/components/*/index.d.ts",
      "import": "./dist/components/*/index.mjs",
      "require": "./dist/components/*/index.cjs"
    },
    "./*.css": "./dist/components/*/styles.css",
    "./*.scss": "./dist/components/*/styles.scss"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "npm run assets && npm run c2b && storybook dev -p 6006",
    "build": "npm run assets && vite build && vite build -c vite.config.components.ts && vite build -c vite.config.vanilla.ts && vite build -c vite.config.vanilla-motion.ts && node scripts/build-components-scss.mjs && npm run c2b",
    "build-storybook": "npm run assets && storybook build",
    "assets": "node scripts/build-assets.mjs",
    "c2b": "c2b generate",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:storybook": "vitest --project=storybook",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write 'src/**/*.{ts,tsx,scss}'",
    "format:check": "prettier --check 'src/**/*.{ts,tsx,scss}'",
    "typecheck": "tsc --noEmit",
    "size": "size-limit",
    "size:check": "size-limit --limit",
    "prepare": "husky",
    "release": "node release.mjs"
  },
  "size-limit": [
    {
      "path": "dist/index.mjs",
      "limit": "10 kB"
    },
    {
      "path": "dist/style.css",
      "limit": "10 kB"
    }
  ],
  "peerDependencies": {
    "@cuweb/rds-icons": "^0.1.1",
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "keywords": [
    "react",
    "component-library",
    "design-system",
    "carleton",
    "storybook"
  ],
  "author": "Carleton University",
  "license": "SEE LICENSE IN LICENSE",
  "packageManager": "pnpm@10.33.0",
  "devDependencies": {
    "@chromatic-com/storybook": "^5.1.2",
    "@cuweb/rds-icons": "^0.1.5",
    "@eslint/js": "^9.39.4",
    "@size-limit/file": "^12.1.0",
    "@storybook/addon-a11y": "^10.3.6",
    "@storybook/addon-docs": "^10.3.6",
    "@storybook/addon-vitest": "^10.3.6",
    "@storybook/react-vite": "^10.3.6",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@troychaplin/component2block": "^0.5.1",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/browser-playwright": "4.1.3",
    "@vitest/coverage-v8": "4.1.3",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-storybook": "^10.3.6",
    "husky": "^9.1.7",
    "modern-normalize": "^3.0.1",
    "playwright": "^1.59.1",
    "prettier": "^3.8.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sass": "^1.99.0",
    "size-limit": "^12.1.0",
    "storybook": "^10.3.6",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.11",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "date-fns": "^4.1.0"
  }
}
