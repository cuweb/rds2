{
    "prefix": "rds",

    "output": {
        "srcDir": "src/styles/auto",
        "themeDir": "dist/cutheme",
        "fontsDir": "public/fonts",
        "themeable": false
    },

    "tokens": {
        "layout": {
            "contentSize": "1024px",
            "wideSize": "1280px"
        },

        "color": {
            "primary": "#e91c24",
            "primary-dark": "#a21218",
            "secondary": "#426587",
            "secondary-dark": { "value": "#2c3c4e", "cssOnly": true },
            "success": { "value": "#00a32a", "cssOnly": true },
            "warning": { "value": "#dba617", "cssOnly": true },
            "error": { "value": "#e91c24", "cssOnly": true },
            "info": { "value": "#72aee6", "cssOnly": true },
            "black": "#191919",
            "grey-dark": "#434343",
            "grey": "#767676",
            "grey-light": "#d6d6d6",
            "grey-lighter": "#e6e6e6",
            "grey-pale": "#f5f5f5",
            "grey-faint": "#fafafa",
            "white": "#ffffff"
        },

        "gradient": {
            "red-to-dark-red": {
                "value": "linear-gradient(135deg,rgb(233,28,36) 0%,rgb(25,25,25) 100%)",
                "slug": "custom-red-to-dark-red"
            },
            "dark-grey-to-black": {
                "value": "linear-gradient(135deg,rgb(118,118,118) 0%,rgb(25,25,25) 100%)",
                "slug": "custom-dark-grey-to-black"
            }
        },

        "fontFamily": {
            "inter": {
                "value": "Inter, sans-serif",
                "fontFace": [
                    { "weight": "300", "style": "normal", "src": "inter-300-normal.woff2" },
                    { "weight": "400", "style": "normal", "src": "inter-400-normal.woff2" },
                    { "weight": "600", "style": "normal", "src": "inter-600-normal.woff2" },
                    { "weight": "300", "style": "italic", "src": "inter-300-italic.woff2" },
                    { "weight": "400", "style": "italic", "src": "inter-400-italic.woff2" },
                    { "weight": "600", "style": "italic", "src": "inter-600-italic.woff2" }
                ]
            }
        },

        "fontSize": {
            "x-small": { "value": "0.75rem", "fluid": { "min": "0.65rem", "max": "0.75rem" }, "cssOnly": true },
            "small":   { "value": "0.9rem", "fluid": { "min": "0.75rem", "max": "0.9rem" } },
            "medium":  { "value": "1rem", "fluid": { "min": "0.875rem", "max": "1rem" } },
            "large":   { "value": "1.125rem", "fluid": { "min": "1rem", "max": "1.125rem" } },
            "x-large": { "value": "1.25rem", "fluid": { "min": "1.125rem", "max": "1.25rem" } },
            "2x-large": { "value": "1.5rem", "fluid": { "min": "1.25rem", "max": "1.5rem" } },
            "heading-small":   { "value": "1.5rem", "fluid": { "min": "1.25rem", "max": "1.5rem" } },
            "heading-medium":  { "value": "2rem",   "fluid": { "min": "1.75rem", "max": "2rem" } },
            "heading-large":   { "value": "2.5rem", "fluid": { "min": "2rem",    "max": "2.5rem" } },
            "heading-x-large": { "value": "3rem",   "fluid": { "min": "2.5rem",  "max": "3rem" } },
            "heading-primary": { "value": "3.5rem", "fluid": { "min": "3rem",    "max": "3.5rem" } }
        },

        "spacing": {
            "2x-small": { "value": "0.44rem", "slug": "20" },
            "x-small":  { "value": "0.67rem",  "slug": "30" },
            "small":    { "value": "min(1rem, 1vw)",  "slug": "40" },
            "medium":   { "value": "min(1.5rem, 2vw)",   "slug": "50" },
            "large":    { "value": "min(2.25rem, 3vw)",   "slug": "60" },
            "x-large":  { "value": "min(3.38rem, 4vw)",      "slug": "70" },
            "2x-large": { "value": "min(5.06rem, 6vw)",    "slug": "80" }
        },

        "shadow": {
            "natural":  "6px 6px 9px rgba(0, 0, 0, 0.2)",
            "sharp":    "6px 6px 0px rgba(0, 0, 0, 0.2)",
            "outlined": "6px 6px 0px -3px rgb(255, 255, 255), 6px 6px rgb(214, 214, 214)"
        },

        "fontWeight": {
            "light":  "300",
            "normal": "400",
            "medium": "500",
            "bold":   "700"
        },

        "lineHeight": {
            "tight":  "1.2",
            "normal": "1.6",
            "loose":  "1.8"
        },

        "radius": {
            "sm": "2px",
            "md": "4px",
            "lg": "8px"
        }
    },

    "baseStyles": {
        "body": {
            "fontFamily": "inter",
            "fontSize": "large",
            "fontWeight": "300",
            "lineHeight": "normal",
            "color": "black",
            "background": "white"
        },
        "heading": {
            "fontFamily": "inter",
            "color": "black"
        },
        "h1": { "fontSize": "heading-primary", "fontWeight": "600" },
        "h2": { "fontSize": "heading-x-large", "fontWeight": "600" },
        "h3": { "fontSize": "heading-large", "fontWeight": "600" },
        "h4": { "fontSize": "heading-medium", "fontWeight": "600" },
        "h5": { "fontSize": "heading-small", "fontWeight": "600" },
        "h6": { "fontSize": "heading-small", "fontWeight": "600", "fontStyle": "italic" },
        "caption": { "fontSize": "small", "fontStyle": "italic", "fontWeight": "light", "color": "warning" },
        "button": { "color": "white", "background": "primary" },
        "link": { "color": "primary", "hoverColor": "error" },
        "spacing": {
            "blockGap": "medium",
            "padding": {
                "top": "0",
                "right": "large",
                "bottom": "0",
                "left": "large"
            }
        }
    }
}
