{
    "prefix": "rds",

    "output": {
        "srcDir": "src/styles/auto",
        "outputDir": "dist/styles",
        "wpTheme": "dist/wordpress",
        "fontsDir": "public/fonts",
        "themeable": false,
        "emitScssAlongside": true,
        "emitAggregate": true,
        "scssVars": ["mediaQuery", "spacing"]
    },

    "tokens": {
        "layout": {
            "contentSize": "1024px",
            "wideSize": "1280px",
            "maxSize": { "value": "1536px", "cssOnly": true }
        },

        "mediaQuery": {
            "sm": "600px",
            "md": "784px",
            "lg": "1024px",
            "xl": "1280px"
        },

        "color": {
            "primary": "#e91c24",
            "primary-dark": "#a21218",
            "secondary": "#426587",
            "secondary-dark": { "value": "#2c3c4e", "cssOnly": true },
            "black": "#191919",
            "grey-dark": "#434343",
            "grey": "#767676",
            "grey-light": "#d6d6d6",
            "grey-lighter": "#e6e6e6",
            "grey-pale": "#f5f5f5",
            "grey-faint": "#fafafa",
            "white": "#ffffff",
            "purple": { "value": "#636FAC", "cssOnly": true },
            "purple-light": { "value": "#D3DAE9", "cssOnly": true },
            "teal": { "value": "#3A8082", "cssOnly": true },
            "teal-light": { "value": "#C8DAD7", "cssOnly": true },
            "blue": { "value": "#026BC8", "cssOnly": true },
            "success": { "value": "#007c24", "cssOnly": true },
            "warning": { "value": "#f4c83c", "cssOnly": true },
            "error": { "value": "#d31820", "cssOnly": true },
            "info": { "value": "#b8d9f2", "cssOnly": true },
            "linkedin": { "value": "#0A66C2", "cssOnly": true },
            "facebook": { "value": "#1877F2", "cssOnly": true },
            "bluesky": { "value": "#1185FE", "cssOnly": true },
            "twitter": { "value": "#000000", "cssOnly": true },
            "instagram": { "value": "#E4405F", "cssOnly": true },
            "youtube": { "value": "#FF0000", "cssOnly": true },
            "tiktok": { "value": "#010101", "cssOnly": true },
            "orcid": { "value": "#A6CE39", "cssOnly": true }
        },

        "gradient": {
            "red-to-dark-red": {
                "value": "linear-gradient(135deg,rgb(233,28,36) 0%,rgb(25,25,25) 100%)",
                "slug": "custom-red-to-dark-red"
            },
            "dark-grey-to-black": {
                "value": "linear-gradient(135deg,rgb(118,118,118) 0%,rgb(25,25,25) 100%)",
                "slug": "custom-dark-grey-to-black"
            }
        },

        "fontFamily": {
            "inter": {
                "value": "Inter, sans-serif",
                "fontFace": [
                    { "weight": "300", "style": "normal", "src": "inter-300-normal.woff2" },
                    { "weight": "400", "style": "normal", "src": "inter-400-normal.woff2" },
                    { "weight": "500", "style": "normal", "src": "inter-500-normal.woff2" },
                    { "weight": "600", "style": "normal", "src": "inter-600-normal.woff2" },
                    { "weight": "700", "style": "normal", "src": "inter-700-normal.woff2" },
                    { "weight": "300", "style": "italic", "src": "inter-300-italic.woff2" },
                    { "weight": "400", "style": "italic", "src": "inter-400-italic.woff2" },
                    { "weight": "500", "style": "italic", "src": "inter-500-italic.woff2" },
                    { "weight": "600", "style": "italic", "src": "inter-600-italic.woff2" },
                    { "weight": "700", "style": "italic", "src": "inter-700-italic.woff2" }
                ]
            }
        },

        "fontWeight": {
            "light":  "300",
            "normal": "400",
            "medium": "500",
            "semibold": "600",
            "bold":   "700"
        },

        "fontSize": {
            "x-small": { "value": "0.75rem", "fluid": { "min": "0.7rem", "max": "0.75rem" }, "cssOnly": true },
            "small":   { "value": "0.9rem", "fluid": { "min": "0.8rem", "max": "0.9rem" } },
            "medium":  { "value": "1rem", "fluid": { "min": "0.85rem", "max": "1rem" } },
            "large":   { "value": "1.125rem", "fluid": { "min": "0.9rem", "max": "1.125rem" } },
            "x-large": { "value": "1.25rem", "fluid": { "min": "1.05rem", "max": "1.25rem" } },
            "2x-large": { "value": "1.5rem", "fluid": { "min": "1.25rem", "max": "1.5rem" } },
            "heading-small":   { "value": "1.5rem", "fluid": { "min": "1.25rem", "max": "1.5rem" } },
            "heading-medium":  { "value": "2rem",   "fluid": { "min": "1.5rem", "max": "2rem" } },
            "heading-large":   { "value": "2.5rem", "fluid": { "min": "1.75rem", "max": "2.5rem" } },
            "heading-x-large": { "value": "3rem",   "fluid": { "min": "1.875rem",  "max": "3rem" } },
            "heading-primary": { "value": "3.5rem", "fluid": { "min": "2rem", "max": "3.5rem" } }
        },

        "spacing": {
            "2-x-small": { "value": "0.44rem", "slug": "20" },
            "x-small":  { "value": "0.67rem",  "slug": "30" },
            "small":    { "value": "clamp(0.625rem, 1vw, 1rem)",      "slug": "40" },
            "medium":   { "value": "clamp(1rem, 2vw, 1.5rem)",        "slug": "50" },
            "large":    { "value": "clamp(1.5rem, 3vw, 2.25rem)",     "slug": "60" },
            "x-large":  { "value": "clamp(2.5rem, 4vw, 3.38rem)",     "slug": "70" },
            "2-x-large": { "value": "clamp(3.75rem, 6vw, 5.06rem)",   "slug": "80" }
        },

        "shadow": {
            "natural":    "0 10px 15px -3px rgb(0 0 0 / 0.1), 0 4px 6px -4px rgb(0 0 0 / 0.1)",
            "sharp":      "6px 6px 0px rgba(0, 0, 0, 0.2)"
        },

        "lineHeight": {
            "tight":  "1.3",
            "normal": "1.6",
            "loose":  "1.8"
        },

        "radius": {
            "sm": "2px",
            "md": "4px",
            "lg": "8px",
            "xl": "12px",
            "full": "9999px"
        }
    },

    "baseStyles": {
        "body": {
            "fontFamily": "inter",
            "fontSize": "large",
            "fontWeight": "300",
            "lineHeight": "normal",
            "color": "black",
            "background": "white"
        },
        "heading": {
            "fontFamily": "inter",
            "color": "grey-dark",
            "lineHeight": "1.1"
        },
        "h1": { "fontSize": "heading-primary", "fontWeight": "600", "marginBlockStart": "x-large" },
        "h2": { "fontSize": "heading-x-large", "fontWeight": "600", "marginBlockStart": "large" },
        "h3": { "fontSize": "heading-large", "fontWeight": "600", "marginBlockStart": "medium" },
        "h4": { "fontSize": "heading-medium", "fontWeight": "600", "marginBlockStart": "medium" },
        "h5": { "fontSize": "heading-small", "fontWeight": "600", "marginBlockStart": "medium" },
        "h6": { "fontSize": "heading-small", "fontWeight": "600", "fontStyle": "italic", "marginBlockStart": "medium" },
        "caption": { "fontSize": "small", "fontStyle": "italic", "fontWeight": "light", "color": "warning" },
        "button": { "color": "white", "background": "primary" },
        "link": { "color": "primary", "hoverColor": "error" },
        "spacing": {
            "blockGap": "0",
            "afterHeading": "small",
            "entryContent": "medium",
            "listItem": "x-small",
            "padding": {
                "top": "0",
                "right": "medium",
                "bottom": "0",
                "left": "medium"
            }
        }
    }
}
